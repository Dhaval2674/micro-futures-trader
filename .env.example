# ============================================================
# TRADING BOT CONFIGURATION
# ============================================================

# === BROKER SELECTION ===
# Options: 'interactive_brokers', 'alpaca'
BROKER_TYPE=interactive_brokers

# === INTERACTIVE BROKERS CONFIGURATION ===
IB_HOST=127.0.0.1
IB_PORT=7497                    # 7497 for live, 7498 for paper trading
IB_CLIENT_ID=1
IB_ACCOUNT=                      # Your IB account ID (e.g., DU1234567)

# === ALPACA CONFIGURATION (FALLBACK) ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading

# === API KEYS ===
NEWSAPI_KEY=                     # Get from https://newsapi.org

# ============================================================
# TRADING PARAMETERS
# ============================================================

# === SYMBOLS TO TRADE ===
# Micro Futures contracts
TRADING_SYMBOLS=MES,MNQ,MGC

# === TIMEFRAME ===
# Data analysis timeframe (in minutes)
# Options: 1, 5, 15, 30, 60, 240
TIMEFRAME=15

# === POSITION SIZING ===
# Risk percentage per trade (e.g., 1 = 1% of account)
RISK_PERCENT=1.0

# ============================================================
# STRATEGY PARAMETERS
# ============================================================

# === MOMENTUM STRATEGY ===
MOMENTUM_RSI_PERIOD=14
MOMENTUM_RSI_OVERBOUGHT=70
MOMENTUM_RSI_OVERSOLD=30
MOMENTUM_MACD_FAST=12
MOMENTUM_MACD_SLOW=26
MOMENTUM_MACD_SIGNAL=9
MOMENTUM_ROC_PERIOD=12

# === MEAN REVERSION STRATEGY ===
MEAN_REVERSION_BB_PERIOD=20
MEAN_REVERSION_BB_STD_DEV=2.0
MEAN_REVERSION_STOCH_K_PERIOD=14
MEAN_REVERSION_STOCH_D_PERIOD=3
MEAN_REVERSION_STOCH_SMOOTH=3

# === SUPPORT/RESISTANCE STRATEGY ===
SR_LOOKBACK_PERIOD=50
SR_MIN_TOUCHES=2
SR_PROXIMITY_PERCENT=0.5

# ============================================================
# RISK MANAGEMENT
# ============================================================

# === STOP LOSS & TAKE PROFIT ===
# As percentage from entry price
STOP_LOSS_PERCENT=0.5
TAKE_PROFIT_PERCENT=1.5

# === MINIMUM RISK/REWARD RATIO ===
MIN_RISK_REWARD_RATIO=1.5

# === POSITION LIMITS ===
# Maximum concurrent positions
MAX_CONCURRENT_POSITIONS=3

# === TRADING HOURS ===
# Market hours (24-hour format)
TRADING_START_HOUR=08
TRADING_END_HOUR=21

# ============================================================
# SENTIMENT ANALYSIS
# ============================================================

# === NEWS SENTIMENT ===
SENTIMENT_NEWS_LOOKBACK_HOURS=24
SENTIMENT_MIN_ARTICLES=5

# === SENTIMENT WEIGHT ===
# Percentage weight in final signal (0-100)
SENTIMENT_WEIGHT=30

# ============================================================
# LOGGING & DEBUG
# ============================================================

# === LOG LEVEL ===
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# === LOG OUTPUT ===
# Options: console, file, both
LOG_OUTPUT=both

# === DEBUG MODE ===
# Enable extra logging and dry-run mode
DEBUG_MODE=false
DRY_RUN=true                    # Don't execute real trades

# ============================================================
# NOTIFICATIONS
# ============================================================

# === EMAIL NOTIFICATIONS ===
SEND_EMAIL_ALERTS=false
EMAIL_FROM=
EMAIL_TO=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=587

# === WEBHOOK NOTIFICATIONS ===
WEBHOOK_ENABLED=false
WEBHOOK_URL=